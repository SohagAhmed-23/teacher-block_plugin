{{!
    @template block_teachers/teacherslist

    Teachers list template for the Teachers block.

    Context variables required for this template:
    * teachers - Array of teacher objects
    * hasteachers - Boolean indicating if there are teachers
}}

<div class="block-teachers-container">
    {{#hasteachers}}
    <div class="teachers-list">
        {{#teachers}}
        <div class="teacher-card mb-3">
            <div class="card-body">
                <div class="teacher-photo mb-3">
                    <a href="{{profileurl}}">{{{picture}}}</a>
                </div>
                <div class="teacher-info">
                    <div class="teacher-details flex-grow-1">
                        <h5 class="teacher-name mb-2">
                            <a href="{{profileurl}}" class="text-decoration-none">{{fullname}}</a>
                        </h5>
                        
                        <div class="teacher-contact mb-2">
                            {{#hasphone}}
                            <div class="contact-item mb-1">
                                <i class="icon fa fa-phone me-1"></i>
                                <small>{{phone}}</small>
                            </div>
                            {{/hasphone}}
                        </div>

                        <div class="teacher-actions">
                            <a href="{{messageurl}}" class="message-button">
                                <i class="icon fa fa-message me-1"></i>
                                {{#str}}messageteacher, block_teachers{{/str}}
                            </a>
                            <a href="mailto:{{email}}" class="email-button">
                                <i class="icon fa fa-envelope me-1"></i>
                                {{#str}} email, block_teachers {{/str}}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {{/teachers}}
    </div>
    {{/hasteachers}}
    
    {{^hasteachers}}
    <div class="alert alert-info">
        <i class="icon fa fa-info-circle me-2"></i>
        {{#str}}noteachers, block_teachers{{/str}}
    </div>
    {{/hasteachers}}
</div>
